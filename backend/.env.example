# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────────
# Use MongoDB Atlas for production: mongodb+srv://user:pass@cluster.mongodb.net/civic
MONGO_URI=mongodb://localhost:27017/civic_issues

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_secret_string
JWT_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── File Upload ──────────────────────────────────────────────────────────────
# 'local' stores files in /uploads folder
# 'cloudinary' sends to Cloudinary (fill keys below)
UPLOAD_MODE=local
MAX_FILE_SIZE_MB=2

# Cloudinary (only needed if UPLOAD_MODE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
